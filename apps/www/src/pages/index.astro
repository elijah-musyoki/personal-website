---
import Icon from '../components/icons.astro';
import Sidebar from '../components/Sidebar.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Elijah Musyoki">
  <Sidebar />
  <main class="flex-auto min-w-0 mt-6 md:mt-0 flex flex-col px-2 md:px-0">
    <section>
      <h1 class="font-bold text-3xl font-serif">Elijah Musyoki</h1>
      <p class="my-5 max-w-[460px] text-neutral-800 dark:text-neutral-200">
        Hey I'm Elijah,<br />welcome to my website.
      </p>
      <div class="flex items-start md:items-center my-8 flex-col md:flex-row">
        <div
          class="rounded-full grayscale w-[100px] h-[100px] bg-neutral-200 dark:bg-neutral-700 text-neutral-700 dark:text-neutral-200 flex items-center justify-center font-serif text-2xl"
          aria-label="Elijah Musyoki"
        >
          EM
        </div>
      </div>

      <div class="mt-8">
        <h2 class="text-neutral-800 dark:text-neutral-200 mb-6">Find me on:</h2>
        <div class="flex items-center gap-6">
          <a
            href="https://github.com/elijah-musyoki"
            target="_blank"
            rel="noopener noreferrer"
            class="text-neutral-600 dark:text-neutral-400 hover:text-neutral-800 dark:hover:text-neutral-200 transition-all"
            title="GitHub"
          >
            <Icon name="github" class="w-6 h-6" />
          </a>
          <a
            href="https://www.linkedin.com/in/elijah-musyoki-3568871a1/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-neutral-600 dark:text-neutral-400 hover:text-neutral-800 dark:hover:text-neutral-200 transition-all"
            title="LinkedIn"
          >
            <Icon name="linkedin" class="w-6 h-6" />
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
