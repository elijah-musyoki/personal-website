---
import Sidebar from '../components/Sidebar.astro';
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    period: '2024 - Present',
    title: 'Project 1',
    summary:
      'Short placeholder summary for the first project. Replace this with the real problem, outcome, and context later.',
    videoHref: '#',
    repoHref: '#',
  },
  {
    period: '2024 - Present',
    title: 'Project 2',
    summary:
      'Short placeholder summary for the second project. Keep this section brief for now and refine it over time.',
    videoHref: '#',
    repoHref: '#',
  },
  {
    period: '2024 - Present',
    title: 'Project 3',
    summary:
      'Short placeholder summary for the third project. Use this slot for one of the workflows you want to highlight.',
    videoHref: '#',
    repoHref: '#',
  },
];
---

<Layout
  title="Projects | Elijah Musyoki"
  description="Selected projects and workflows built by Elijah Musyoki."
>
  <Sidebar />
  <main class="flex-auto min-w-0 mt-6 md:mt-0 flex flex-col px-2 md:px-0">
    <section>
      <h1 class="font-bold text-3xl font-serif mb-8">Projects</h1>
      <div class="space-y-6">
        {
          projects.map((project) => (
            <div class="flex items-baseline gap-8">
              <span class="text-neutral-500 dark:text-neutral-400 text-sm min-w-[100px]">
                {project.period}
              </span>
              <div>
                <div>
                  <span class="text-neutral-800 dark:text-neutral-200">
                    {project.title}
                  </span>
                  <span class="italic text-xs text-neutral-400 dark:text-neutral-500 ml-2">
                    (featured project)
                  </span>
                </div>
                <p class="text-sm text-neutral-600 dark:text-neutral-400 mt-1 leading-relaxed max-w-2xl">
                  {project.summary}
                </p>
                <div class="mt-2 flex flex-wrap gap-4 text-sm">
                  <a
                    href={project.videoHref}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-neutral-800 dark:text-neutral-200 hover:text-neutral-600 dark:hover:text-neutral-400 transition-all underline decoration-neutral-300 dark:decoration-neutral-600 hover:decoration-neutral-500"
                  >
                    Watch walkthrough
                  </a>
                  <a
                    href={project.repoHref}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-neutral-800 dark:text-neutral-200 hover:text-neutral-600 dark:hover:text-neutral-400 transition-all underline decoration-neutral-300 dark:decoration-neutral-600 hover:decoration-neutral-500"
                  >
                    View repo
                  </a>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </section>
  </main>
</Layout>
