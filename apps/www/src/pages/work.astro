---
import Sidebar from '../components/Sidebar.astro';
import Layout from '../layouts/Layout.astro';

const roles = [
  {
    period: '2022 - Present',
    company: 'Rift Works',
    href: null,
    title: 'Automation Consultant',
    description:
      'Builds business process automations, backend integrations, and workflow systems for real teams.',
  },
  {
    period: '2022 - Present',
    company: 'Rift Works',
    href: null,
    title: 'BPA / Backend Engineer',
    description:
      'Focuses on making workflows simpler, faster, and less manual through practical systems and clean integrations.',
  },
  {
    period: '2022 - Present',
    company: 'Rift Works',
    href: null,
    title: 'Automation Engineer',
    description:
      'Works across automations, internal tools, and business process improvements, with room to refine the wording later.',
  },
];
---

<Layout
  title="Work | Elijah Musyoki"
  description="Automation Consultant. A timeline of where I've worked."
>
  <Sidebar />
  <main class="flex-auto min-w-0 mt-6 md:mt-0 flex flex-col px-2 md:px-0">
    <section>
      <h1 class="font-bold text-3xl font-serif mb-8">Work</h1>
      <div class="space-y-6">
        {
          roles.map((role) => (
            <div class="flex items-baseline gap-8">
              <span class="text-neutral-500 dark:text-neutral-400 text-sm min-w-[100px]">
                {role.period}
              </span>
              <div>
                <div>
                  {role.href ? (
                    <a
                      href={role.href}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-neutral-800 dark:text-neutral-200 hover:text-neutral-600 dark:hover:text-neutral-400 transition-all underline decoration-neutral-300 dark:decoration-neutral-600 hover:decoration-neutral-500"
                    >
                      {role.company}
                    </a>
                  ) : (
                    <span class="text-neutral-800 dark:text-neutral-200">
                      {role.company}
                    </span>
                  )}
                  <span class="italic text-neutral-500 dark:text-neutral-400 ml-2">
                    {role.title}
                  </span>
                </div>
                <p class="text-sm text-neutral-600 dark:text-neutral-400 mt-1 leading-relaxed">
                  {role.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </section>
  </main>
</Layout>
